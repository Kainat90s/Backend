# ByteSlot Environment Configuration
# Copy this file to .env and fill in your values for production.

# --- Django Settings ---
SECRET_KEY=generate-a-new-secure-key-for-production # Use a random 50+ character string
DEBUG=False
ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com

# --- Database ---
# Local default (recommended for quick setup)
DB_ENGINE=sqlite3
SQLITE_NAME=db.sqlite3

# MS SQL Server (use this in production if needed)
# DB_ENGINE=mssql
# DB_NAME=byteslot_prod
# DB_HOST=your-db-server-address
# DB_PORT=1433
# DB_USER=your_db_user
# DB_PASSWORD=your_db_password
# DB_DRIVER=ODBC Driver 17 for SQL Server
# DB_TRUSTED_CONNECTION=no

# --- CORS Settings ---
# Add your frontend production URL here
CORS_ALLOWED_ORIGINS=https://yourdomain.com

# --- Celery + Redis ---
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# --- Email Settings (SMTP) ---
# Recommend using a provider like SendGrid, Mailgun, or Gmail App Passwords
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@example.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=ByteSlot Notifications <your-email@example.com>

# --- Google OAuth 2.0 ---
# Create these in Google Cloud Console
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
# IMPORTANT: This must match the Authorized Redirect URI in Google Console
GOOGLE_REDIRECT_URI=https://yourdomain.com/api/integrations/google/callback/
